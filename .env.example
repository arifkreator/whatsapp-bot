# ============================================
# GROQ API KEY — GRATIS dari console.groq.com
# Tidak butuh kartu kredit!
# ============================================

# Key utama (wajib)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Key tambahan opsional (untuk rotasi jika rate limit)
# Buat akun Groq berbeda, masing-masing dapat quota gratis
# GROQ_API_KEY_1=gsk_yyyyyyyy
# GROQ_API_KEY_2=gsk_zzzzzzzz

# Model (pilih salah satu):
#   llama-3.3-70b-versatile  ← RECOMMENDED: paling pintar, gratis
#   llama3-8b-8192           ← paling cepat & ringan
#   gemma2-9b-it             ← alternatif, bagus untuk chat
#   mixtral-8x7b-32768       ← konteks sangat panjang
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================
# KONFIGURASI BOT
# ============================================

BOT_NAME=BotKu
BOT_PREFIX=!
OWNER_NUMBER=6281234567890

# ============================================
# KONFIGURASI AI
# ============================================

AI_AUTO_REPLY_PRIVATE=true
AI_AUTO_REPLY_GROUP=true
AI_MAX_TOKENS=1024

# Cooldown antar request per user (detik)
AI_COOLDOWN_SECONDS=5

# Kepribadian bot
AI_SYSTEM_PROMPT=Kamu adalah asisten WhatsApp yang helpful, ramah, dan menjawab dalam Bahasa Indonesia. Jawaban singkat dan padat, maksimal 3-4 kalimat kecuali diminta detail.

# ============================================
# KONFIGURASI ANTI-SPAM
# ============================================

SPAM_MAX_MESSAGES=5
SPAM_TIME_WINDOW=10
SPAM_MUTE_DURATION=300
